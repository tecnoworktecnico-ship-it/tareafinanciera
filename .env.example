# ==========================================
# GLOBLAL CONFIGURATION
# ==========================================
DEFAULT_BASE_CURRENCY=USD

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
BACKEND_PORT=3001
DB_PATH=./database.sqlite

# ==========================================
# ANALYTICS ENGINE CONFIGURATION
# ==========================================
# Proveedor de cotizaciones de divisas.
# Nota: ExchangeRate-API soporta ARS y PEN en su plan gratuito.
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/
EXCHANGE_RATE_API_KEY=your_free_api_key_here

# (Alternativa) Si decides usar Frankfurter API (sin API key, pero sujeto a su listado de monedas publicado por ECB):
# EXCHANGE_RATE_API_URL=https://api.frankfurter.app

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
VITE_API_URL=http://localhost:3001
VITE_DEFAULT_CURRENCY=USD
