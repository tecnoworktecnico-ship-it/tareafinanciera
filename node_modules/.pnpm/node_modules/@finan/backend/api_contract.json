{
  "swagger": "2.0",
  "info": {
    "title": "Smart Expense Tracker Multi-Moneda API",
    "description": "API Contract para el backend del sistema",
    "version": "1.0.0"
  },
  "host": "localhost:3001",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/api/accounts": {
      "get": {
        "tags": [
          "Accounts"
        ],
        "description": "Obtener todas las cuentas",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Accounts"
        ],
        "description": "Crear una cuenta",
        "parameters": [
          {
            "name": "newAccount",
            "in": "body",
            "description": "Nueva cuenta",
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "example": "Cuenta Principal"
                },
                "currency": {
                  "type": "string",
                  "example": "USD"
                },
                "balance": {
                  "type": "number",
                  "example": 1000
                }
              },
              "required": [
                "name",
                "currency",
                "balance"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/transactions": {
      "get": {
        "tags": [
          "Transactions"
        ],
        "description": "Obtener historial de transacciones",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Transactions"
        ],
        "description": "Registrar una transacción (Gasto, Ingreso o Transferencia)",
        "parameters": [
          {
            "name": "newTransaction",
            "in": "body",
            "description": "Nueva transacción",
            "schema": {
              "type": "object",
              "properties": {
                "accountId": {
                  "type": "string",
                  "example": "123"
                },
                "amount": {
                  "type": "number",
                  "example": 150.5
                },
                "type": {
                  "type": "string",
                  "example": "EXPENSE"
                },
                "category": {
                  "type": "string",
                  "example": "Food"
                },
                "description": {
                  "type": "string",
                  "example": "Almuerzo"
                }
              },
              "required": [
                "accountId",
                "amount",
                "type",
                "category",
                "description"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/config": {
      "get": {
        "tags": [
          "Config"
        ],
        "description": "Obtener configuración del sistema (moneda base, etc.)",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}